# Tractatus Supabase Configuration
# Replace with your actual values from Supabase Dashboard > Project Settings > API
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# For native OAuth redirects (add this in Supabase Auth > URL Configuration)
# com.tractatus.app://auth/callback

# Cloudflare R2 (for profile picture uploads)
# Create a bucket and generate API tokens in Cloudflare Dashboard > R2
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=tractatus-avatars
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev
