# Dependencies
node_modules
.pnp
.pnp.js

# SvelteKit / Vite
.svelte-kit
.output
build
dist

# Capacitor platforms
# We commit android/ and ios/ (custom plugins like UpdaterPlugin.java live here).
# Only ignore build artifacts, Gradle caches, and generated public web assets.
android/app/build/
android/.gradle/
android/local.properties
android/app/src/main/assets/
ios/App/build/
ios/App/Pods/
ios/App/App/public/

# Generated assets (from icon generation scripts)
assets/

# Android signing keys (never commit!)
scripts/android-signing/
!scripts/android-signing/.gitkeep

# Vercel / deployment
.vercel
.netlify

# Environment variables (never commit real secrets)
.env
.env.*
!.env.example
!.env.test.example

# Supabase local state
supabase/.branches
supabase/.temp
supabase/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors
.idea
.vscode
*.swp
*.swo
*~

